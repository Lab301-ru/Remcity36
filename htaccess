# ═══════════════════════════════════════════════════
#  Ремсити36 — .htaccess для максимальной производительности
#  Решает: "Выбирайте эффективный период хранения кеша -215 КиБ"
# ═══════════════════════════════════════════════════

# ─── СЖАТИЕ GZIP ──────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/ld+json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2 application/font-woff application/font-woff2
</IfModule>

# ─── BROTLI (если поддерживается сервером) ────────
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css
  AddOutputFilterByType BROTLI_COMPRESS text/javascript application/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/json application/ld+json
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
  AddOutputFilterByType BROTLI_COMPRESS font/woff font/woff2
</IfModule>

# ─── КЕШИРОВАНИЕ СТАТИКИ ──────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Изображения — 1 год
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/gif               "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/x-icon            "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon "access plus 1 year"

  # Шрифты — 1 год
  ExpiresByType font/woff               "access plus 1 year"
  ExpiresByType font/woff2              "access plus 1 year"
  ExpiresByType application/font-woff   "access plus 1 year"
  ExpiresByType application/font-woff2  "access plus 1 year"

  # CSS и JS — 1 месяц
  ExpiresByType text/css                "access plus 1 month"
  ExpiresByType text/javascript         "access plus 1 month"
  ExpiresByType application/javascript  "access plus 1 month"

  # HTML — 1 день (чтобы обновления видели быстро)
  ExpiresByType text/html               "access plus 1 day"

  # JSON / манифест — 1 неделя
  ExpiresByType application/json        "access plus 1 week"
  ExpiresByType application/manifest+json "access plus 1 week"
</IfModule>

# ─── Cache-Control заголовки ──────────────────────
<IfModule mod_headers.c>
  # Изображения и шрифты — иммутабельный кеш на год
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # CSS и JS — версионированный кеш
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML — короткий кеш
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Безопасность
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ─── ETag отключаем (дублирует кеш) ──────────────
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None

# ─── РЕДИРЕКТ www → без www ───────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
</IfModule>
